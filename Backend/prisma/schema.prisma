generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  PROJECT_MANAGER
  TEAM_MEMBER
}

enum TaskType {
  DEVELOPMENT
  DESIGN
  TESTING
  MANAGEMENT
  SUPPORT
  DOCUMENTATION
  MEETING
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                UserRole  @default(TEAM_MEMBER)
  employeeId          String?   @unique
  department          String?
  active              Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  refreshTokens        RefreshToken[]
  tasksCreated         Task[]           @relation("TaskCreatedBy")
  assignments          TaskAssignment[] @relation("AssignedToUser")
  assignedBy           TaskAssignment[] @relation("AssignedByUser")
  timesheets           Timesheet[]      @relation("TimesheetOwner")
  timesheetsApprovedBy Timesheet[]      @relation("TimesheetApprover")

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Project {
  id               String        @id @default(uuid())
  code             String        @unique
  name             String
  description      String?
  startDate        DateTime?
  endDate          DateTime?
  status           ProjectStatus @default(ACTIVE)
  projectManagerId String?
  clientName       String?
  budget           Decimal?      @db.Decimal(12, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tasks Task[]

  @@index([code])
  @@index([status])
  @@map("projects")
}

model Task {
  id          String       @id @default(uuid())
  projectId   String
  name        String
  description String?
  taskType    TaskType     @default(DEVELOPMENT)
  priority    TaskPriority @default(MEDIUM)
  startDate   DateTime?
  endDate     DateTime?
  billable    Boolean      @default(true)
  status          TaskStatus   @default(ACTIVE)
  creationStatus  String       @default("ON_TIME_CREATION")
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  project          Project          @relation(fields: [projectId], references: [id])
  createdBy        User             @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignments      TaskAssignment[]
  timesheetEntries TimesheetEntry[]

  @@index([projectId])
  @@index([status])
  @@map("tasks")
}

model TaskAssignment {
  id                   String           @id @default(uuid())
  taskId               String
  employeeId           String
  assignStartDate      DateTime
  assignEndDate        DateTime
  allocationPercentage Int              @default(100)
  roleOnTask           String?
  status               AssignmentStatus @default(ACTIVE)
  assignedById         String
  assignedAt           DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  task       Task @relation(fields: [taskId], references: [id])
  employee   User @relation("AssignedToUser", fields: [employeeId], references: [id])
  assignedBy User @relation("AssignedByUser", fields: [assignedById], references: [id])

  @@index([taskId])
  @@index([employeeId])
  @@map("task_assignments")
}

model Timesheet {
  id              String          @id @default(uuid())
  employeeId      String
  weekStartDate   DateTime
  weekEndDate     DateTime
  status          TimesheetStatus @default(DRAFT)
  totalHours      Decimal         @default(0) @db.Decimal(8, 2)
  submittedAt     DateTime?
  approvedAt      DateTime?
  approvedById    String?
  rejectedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  employee   User             @relation("TimesheetOwner", fields: [employeeId], references: [id])
  approvedBy User?            @relation("TimesheetApprover", fields: [approvedById], references: [id])
  entries    TimesheetEntry[]

  @@unique([employeeId, weekStartDate])
  @@index([employeeId])
  @@index([status])
  @@index([weekStartDate])
  @@map("timesheets")
}

// ── Admin-uploaded project/task config ────────────────────────────────────────
model ProjectConfig {
  id          String   @id @default(uuid())
  code        String   @unique   // e.g. "ACRT"
  name        String             // e.g. "ACRT"
  client      String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taskNames   TaskNameConfig[]

  @@index([active])
  @@map("project_configs")
}

model TaskNameConfig {
  id              String        @id @default(uuid())
  projectConfigId String
  name            String        // e.g. "Pipeline Development"
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())

  projectConfig   ProjectConfig @relation(fields: [projectConfigId], references: [id], onDelete: Cascade)

  @@unique([projectConfigId, name])
  @@index([projectConfigId])
  @@map("task_name_configs")
}

model TimesheetEntry {
  id          String   @id @default(uuid())
  timesheetId String
  projectId   String
  taskId      String
  monday      Decimal  @default(0) @db.Decimal(5, 2)
  tuesday     Decimal  @default(0) @db.Decimal(5, 2)
  wednesday   Decimal  @default(0) @db.Decimal(5, 2)
  thursday    Decimal  @default(0) @db.Decimal(5, 2)
  friday      Decimal  @default(0) @db.Decimal(5, 2)
  saturday    Decimal  @default(0) @db.Decimal(5, 2)
  sunday      Decimal  @default(0) @db.Decimal(5, 2)
  totalHours  Decimal  @default(0) @db.Decimal(8, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id])

  @@index([timesheetId])
  @@index([taskId])
  @@map("timesheet_entries")
}

// ── Email notification settings: editable by SUPER_ADMIN only (IST schedules).
//    Recipients are all active users except SUPER_ADMIN (includes COMPANY_ADMIN as employees).
model AppNotificationSettings {
  id String @id @default("global")

  timezone            String @default("Asia/Kolkata")
  weeklyReminderEnabled Boolean @default(true)

  /// JSON array: { id, statusKey, enabled, weekdaysMonFirst: number[], hour: 0-23, minute: 0-59 }[]
  /// statusKey: NOT_INITIATED | DRAFT | SUBMITTED | REJECTED
  /// weekdaysMonFirst: 1=Mon .. 7=Sun
  statusReminderRules Json @default("[]")

  updatedAt DateTime @updatedAt
  updatedById String?

  @@map("app_notification_settings")
}

/// One row per actual send — prevents duplicate emails same calendar day (IST) per rule/week.
model NotificationDeliveryLog {
  id     String @id @default(uuid())
  userId String
  channel String @default("email")
  kind    String
  weekKey String
  ruleId  String
  dayYmd  String
  sentAt  DateTime @default(now())

  @@unique([userId, kind, weekKey, ruleId, dayYmd])
  @@index([sentAt])
  @@index([userId])
  @@map("notification_delivery_logs")
}
